{
  "manifest_version": 3,
  "name": "Homo Party",
  "version": "2.0.3",
  "description": "YouTube、Amazon Prime Video、ニコニコ動画の再生状態をルーム内で同期します。",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://rimworld-inm.duckdns.org/*"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Homo Party",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*",
        "https://www.amazon.com/*",
        "https://www.amazon.co.jp/*",
        "https://www.primevideo.com/*",
        "https://www.nicovideo.jp/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
